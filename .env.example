# Premium Peptides Lab — environment template
# Copy to .env.local and fill in values (never commit .env.local)

# Supabase (browser + server; anon key is safe for client with RLS)
# New project (after DB migration) — ref fwzantgfbvtfpzujgmjr
NEXT_PUBLIC_SUPABASE_URL=https://fwzantgfbvtfpzujgmjr.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only (bypass RLS — checkout API, scripts). Never use NEXT_PUBLIC_ prefix.
SUPABASE_SERVICE_ROLE_KEY=

# Public site URL (production). Used for metadata when not localhost.
NEXT_PUBLIC_SITE_URL=https://premiumpeptideslab.online

# Optional override for email/form links (defaults to production when env is localhost)
# EMAIL_SITE_URL=https://premiumpeptideslab.online

# Contact form + transactional email (Resend — https://resend.com)
# RESEND_API_KEY=re_xxxxxxxx
# EMAIL_FROM=Premium Peptides Lab <info@premiumpeptideslab.online>
# ADMIN_EMAIL=info@premiumpeptideslab.online
# Logo is embedded inline in emails. Optional: public URL for image fallbacks (defaults to production if SITE_URL is localhost)
# EMAIL_SITE_URL=https://premiumpeptideslab.online
